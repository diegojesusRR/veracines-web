---
import { ViewTransitions } from "astro:transitions"

import ButtonUp from "@/components/ButtonUp.astro"
import Header from "@/components/Header.astro"

import SEO from "@/components/SEO.astro"
import type { Preload } from "@/types/Preload"

import Toast from "@/components/ui/Toast.astro"
import Footer from "@/sections/Footer.astro"
import "@fontsource-variable/jost"

interface Props {
	title: string
	description: string
	preload?: Array<Preload>
	canonical?: string
	image?: string
}

const { title, description, preload, canonical, image } = Astro.props
---

<!doctype html>
<html lang="es">
	<head>
		<!-- Anti-flash dark mode: aplica la clase antes del primer paint -->
		<script is:inline>
			;(function () {
				const stored = localStorage.getItem("theme")
				const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches
				if (stored === "dark" || (!stored && prefersDark)) {
					document.documentElement.classList.add("dark")
				}
			})()
		</script>
		<!-- Persistir tema en navegaciones con View Transitions -->
		<script is:inline>
			document.addEventListener("astro:before-swap", function (e) {
				const isDark = document.documentElement.classList.contains("dark")
				if (isDark) {
					e.newDocument.documentElement.classList.add("dark")
				} else {
					e.newDocument.documentElement.classList.remove("dark")
				}
			})
		</script>
		<script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="c4820152-a570-4c39-b715-fbc8a232cbf9" data-blockingmode="auto" type="text/javascript"></script>
		<script>
			// Notificar a Cookiebot tras cada navegación con ViewTransitions
			document.addEventListener("astro:after-swap", () => {
				const w = window as Window & { Cookiebot?: { runScripts: () => void } }
				if (typeof w.Cookiebot !== "undefined") {
					w.Cookiebot.runScripts()
				}
			})
		</script>
		<SEO
			canonical={canonical}
			description={description}
			image={image}
			preload={preload}
			title={title}
		/>

		<ViewTransitions />
		<slot name="head" />
	</head>

	<body class="overflow-x-hidden selection:bg-primary [&_:focus-visible]:outline-none [&_:focus-visible]:ring-2 [&_:focus-visible]:ring-primary">
		<Header />
			<slot />
			<Footer />
			<Toast />
		<div class="bg-primary border-primary text-primary" style="display: none"></div>
		<div class="bg-secondary border-secondary text-secondary" style="display: none"></div>

		<ButtonUp />
		<style is:global>
			:root {
				--color-secondary: #dc3545;
				--color-primary: #2e4390;

				--color-azul: #2e4390;
				--color-rojo: #dc3545;

				--background-color: repeating-linear-gradient(
					135deg,
					#f7f7f7,
					#fafafa 25%,
					#ffffff 25%,
					#fcfcfc 25%
				);

				--background-color-white: #ffffff;
				--card-bg: rgba(255, 255, 255, 0.9);
				--card-bg-blur: rgba(255, 255, 255, 0.85);
				--text-muted: #4b5563;
				--border-subtle: #f3f4f6;
				--surface: #f9fafb;
			}

			html.dark {
				/* Los colores de fondo (bg-primary, bg-secondary, border-primary…)
				   conservan los valores originales para mantener la identidad visual.
				   Solo se aclaran cuando se usan como color de texto. */

				--background-color: repeating-linear-gradient(
					135deg,
					#0d0d0d,
					#101010 25%,
					#121212 25%,
					#111111 25%
				);

				--background-color-white: #111827;
				--card-bg: rgba(17, 24, 39, 0.92);
				--card-bg-blur: rgba(17, 24, 39, 0.88);
				--text-muted: #9ca3af;
				--border-subtle: #1f2937;
				--surface: #1f2937;
			}

			/* En dark mode, solo los colores de TEXTO se aclaran para garantizar
			   contraste sobre fondos oscuros. Los fondos y bordes conservan
			   el color de marca original. */

			/* Clases Tailwind */
			html.dark .text-primary,
			html.dark .hover\:text-primary:hover {
				color: #7b9ef0; /* azul claro – ratio WCAG AA sobre #111827 */
			}
			html.dark .text-secondary,
			html.dark .hover\:text-secondary:hover {
				color: #f97086; /* coral claro – ratio WCAG AA sobre #111827 */
			}

			/* Clases CSS de componentes que usan color: var(--cine-color) como texto */
			html.dark .proyeccion-title,
			html.dark .dia-label,
			html.dark .sin-proyecciones,
			html.dark .cine-card__day,
			html.dark .ubicacion-title,
			html.dark .cartelera-title,
			html.dark .cartelera-subtitle {
				color: color-mix(in srgb, var(--cine-color) 55%, white);
			}

			@font-face {
				font-family: Atomic;
				font-display: swap;
				src: url("/fonts/atomic.woff2") format("woff2");
			}

			html {
				font-family: "Jost Variable", system-ui, sans-serif;
				background: var(--background-color);
				scrollbar-gutter: stable;
				color-scheme: light;
			}

			html.dark {
				color-scheme: dark;
			}

			body {
				color: #1a1a1a;
			}

			html.dark body {
				color: #e5e7eb;
			}

			main {
				position: relative;
			}

			body {
				&:has(dialog[open]) {
					overflow: hidden;
				}
			}

			/* Hiding class, making content visible only to screen readers but not visually */
			/* "sr" meaning "screen-reader" */
			.sr-only:not(:focus):not(:active) {
				clip: rect(0 0 0 0);
				clip-path: inset(50%);
				height: 1px;
				overflow: hidden;
				position: absolute;
				white-space: nowrap;
				width: 1px;
			}

			@supports selector(::-webkit-scrollbar) {
				::-webkit-scrollbar {
					width: 10px;
					border-radius: 10px;
				}

				::-webkit-scrollbar-thumb {
					border-radius: 10px;
					background-color: theme("colors.primary");
					border: 2px solid transparent;
					background-clip: content-box;
				}

				::-webkit-scrollbar-thumb:active {
					background-color: #666;
				}

				::-webkit-scrollbar-track {
					background: var(--background-image);
				}

				::-webkit-scrollbar-corner {
					background: var(--background-image);
				}
			}

			@supports not selector(::-webkit-scrollbar) {
				* {
					scrollbar-color: theme("colors.primary") transparent;
					scrollbar-width: thin;
				}
			}

			.anchor-main-content {
				pointer-events: none;
			}

			.anchor-main-content:focus {
				pointer-events: all;
			}

			/* Dark mode toast override */
			html.dark .butteruptoast {
				background-color: #1f2937;
				border-color: #374151;
				color: #e5e7eb;
			}
			html.dark .butteruptoast .icon svg {
				fill: #e5e7eb;
			}
		</style>
	</body>
</html>
