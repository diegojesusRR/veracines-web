---
import {GRUPOSPROYECCIONES} from "../consts/proyecciones";

const MESES = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
const DIASSEMANA = ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'];
const now = new Date();

const grupos = GRUPOSPROYECCIONES
    .map(g => ({
        ...g,
        proximasProyecciones: g.proyecciones
            .filter(p => p.fecha >= now)
            .sort((a, b) => a.fecha.getTime() - b.fecha.getTime())
    }))
    .filter(g => g.proximasProyecciones.length > 0)
    .sort((a, b) =>
        a.proximasProyecciones[0].fecha.getTime() - b.proximasProyecciones[0].fecha.getTime()
    )
    .map(g => {
        // Agrupar proyecciones por día
        const diasMap = new Map<string, { label: string; horas: string[] }>();
        g.proximasProyecciones.forEach(p => {
            const key = `${p.fecha.getFullYear()}${String(p.fecha.getMonth()).padStart(2, '0')}${String(p.fecha.getDate()).padStart(2, '0')}`;
            if (!diasMap.has(key)) {
                diasMap.set(key, {
                    label: `${DIASSEMANA[p.fecha.getDay()]} ${p.fecha.getDate()}`,
                    horas: []
                });
            }
            diasMap.get(key)!.horas.push(`${p.hora}h${p.vose ? ' (V)' : ''}`);
        });
        const dias = [...diasMap.entries()]
            .sort((a, b) => a[0].localeCompare(b[0]))
            .map(([, v]) => v);
        return {...g, dias};
    });
---

{grupos.length > 0 && (
<section aria-labelledby="carousel-titulo" class="w-full overflow-x-clip">

    <div class="flex items-center justify-between mb-4">
        <h2 id="carousel-titulo" class="text-2xl font-extrabold text-primary">
            Próximas proyecciones
        </h2>
        <div class="flex gap-2">
            <button id="carousel-prev" aria-label="Anterior" class="carousel-btn">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                </svg>
            </button>
            <button id="carousel-next" aria-label="Siguiente" class="carousel-btn">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24"
                     stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- Viewport -->
    <div class="w-full sm:max-w-3xl mx-auto overflow-hidden rounded-2xl shadow-xl">
        <div id="carousel-viewport" class="relative w-full">
            <div id="carousel-track" class="flex"
                 style="width: 100%; transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1); will-change: transform;">
                {grupos.map(({cine, pelicula, dias, colaboracion}, i) => (
                        <a
                                href={`/peliculas/${pelicula.id}`}
                                class="carousel-slide block overflow-hidden"
                                style={`--cine-color: var(--color-${cine.color}); flex: 0 0 100%; max-width: 100%;`}
                                aria-hidden={i !== 0}
                        >
                            <!-- MOBILE: imagen de fondo + info superpuesta -->
                            <div class="relative sm:hidden aspect-[2/3]">
                                <img
                                        src={`/img/peliculas/${pelicula.image}`}
                                        alt={`Cartel de ${pelicula.nombre}`}
                                        class="absolute inset-0 w-full h-full object-cover object-top"
                                        loading={i === 0 ? 'eager' : 'lazy'}
                                        decoding="async"
                                        width="400" height="600"
                                        data-poster-id={pelicula.id}
                                />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
                                <div class="absolute bottom-0 left-0 right-0 p-4 flex flex-col gap-3">
                                    <div>
                            <div class="flex items-center gap-2 mb-2">
                                <span class="inline-block cine-badge text-white text-[10px] font-bold px-2.5 py-1 rounded-full">
                                    {cine.nombre}
                                </span>
                                {colaboracion && (
                                    <div class="flex flex-col leading-tight">
                                        <span class="text-[9px] text-white/70 font-semibold uppercase tracking-wider">Colabora con:</span>
                                        {colaboracion.logo ? (
                                            <img src={colaboracion.logo} alt={colaboracion.nombre} class="h-3.5 w-auto object-contain brightness-150 mt-0.5" loading="lazy" decoding="async" />
                                        ) : (
                                            <span class="text-white text-[11px] font-bold">{colaboracion.nombre}</span>
                                        )}
                                    </div>
                                )}
                            </div>
                                        <h3 class="text-white text-2xl font-extrabold leading-tight drop-shadow">
                                            {pelicula.nombre}
                                        </h3>
                                    </div>
                                    <div class="grid grid-cols-3 gap-1.5">
                                        {dias.slice(0, 6).map(dia => (
                                                <div class="rounded-lg bg-white/15 backdrop-blur-sm border border-white/20 px-2 py-1.5 text-center">
                                                    <p class="text-white text-[11px] font-bold leading-tight">{dia.label}</p>
                                                    <p class="text-white/70 text-[10px] mt-0.5">{dia.horas.join(', ')}</p>
                                                </div>
                                        ))}
                                    </div>
                                </div>
                            </div>

                            <!-- DESKTOP: info izquierda + póster derecha -->
                            <div class="hidden sm:flex relative h-[320px] overflow-hidden w-full max-w-full rounded-2xl">
                                <img
                                        src={`/img/peliculas/${pelicula.image}`}
                                        alt="" aria-hidden="true"
                                        class="absolute inset-0 w-full h-full object-cover scale-110 blur-lg brightness-[0.25]"
                                        loading={i === 0 ? 'eager' : 'lazy'}
                                        decoding="async"
                                        width="800" height="450"
                                />
                                <div class="relative z-10 flex items-center justify-between gap-8 p-8 w-full">
                                    <!-- Info izquierda -->
                                    <div class="flex flex-col justify-between flex-1 min-w-0 h-full">
                                        <div>
                                            <div class="flex items-center gap-3 mb-3">
                                                <span class="inline-block cine-badge text-white text-[10px] font-bold px-2.5 py-1 rounded-full">
                                                    {cine.nombre}
                                                </span>
                                                {colaboracion && (
                                                    <div class="flex flex-col leading-tight">
                                                        <p class="text-[9px] font-semibold uppercase tracking-widest text-white/40">Colabora con:</p>
                                                        {colaboracion.logo ? (
                                                            <img src={colaboracion.logo} alt={colaboracion.nombre} class="h-4 w-auto object-contain brightness-150 mt-0.5" loading="lazy" decoding="async" />
                                                        ) : (
                                                            <p class="text-xs font-bold text-white/80">{colaboracion.nombre}</p>
                                                        )}
                                                    </div>
                                                )}
                                            </div>
                                            <h3 class="text-white text-3xl font-extrabold leading-tight drop-shadow">
                                                {pelicula.nombre}
                                            </h3>
                                            <p class="text-white/50 text-xs mt-1">{pelicula.edadRedomendada}</p>
                                        </div>
                                        <!-- Grid de días -->
                                        <div class="grid grid-cols-3 gap-2">
                                            {dias.slice(0, 6).map(dia => (
                                                    <div class="rounded-lg border border-white/20 bg-white/10 backdrop-blur-sm px-3 py-2 text-center">
                                                        <p class="text-white text-xs font-bold leading-tight">{dia.label}</p>
                                                        <p class="text-white/60 text-[11px] mt-0.5">{dia.horas.join(', ')}</p>
                                                    </div>
                                            ))}
                                        </div>
                                    </div>

                                    <!-- Póster derecha -->
                                    <div class="shrink-0 w-44">
                                        <img
                                                src={`/img/peliculas/${pelicula.image}`}
                                                alt={`Cartel de ${pelicula.nombre}`}
                                                class="w-full rounded-xl border-4 border-white/30 shadow-2xl object-cover"
                                                loading={i === 0 ? 'eager' : 'lazy'}
                                                decoding="async"
                                                width="176" height="264"
                                                data-poster-id={pelicula.id}
                                        />
                                    </div>
                                </div>
                            </div>
                        </a>
                ))}
            </div>
        </div>
    </div>

    <!-- Dots -->
    <div id="carousel-dots" class="flex justify-center items-center gap-3 mt-4" role="tablist"></div>

</section>
    )}

<style>
    .carousel-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 9999px;
        border: 1.5px solid var(--color-primary);
        color: var(--color-primary);
        background: white;
        cursor: pointer;
        transition: background 0.2s, color 0.2s;
    }

    :global(html.dark) .carousel-btn {
        background: #111827;
    }

    .carousel-btn:hover {
        background: var(--color-primary);
        color: white;
    }

    .carousel-btn:disabled {
        opacity: 0.3;
        cursor: default;
    }

    .cine-badge {
        background-color: var(--cine-color);
    }
</style>

<script>
    function setupCarousel() {
        const viewport = document.getElementById('carousel-viewport');
        const track = document.getElementById('carousel-track') as HTMLElement | null;
        const prevBtn = document.getElementById('carousel-prev') as HTMLButtonElement | null;
        const nextBtn = document.getElementById('carousel-next') as HTMLButtonElement | null;
        const dotsEl = document.getElementById('carousel-dots');
        if (!viewport || !track || !prevBtn || !nextBtn || !dotsEl) return;

        // Guard: evita reinicializar el mismo carrusel
        if (viewport.dataset.carouselSetup === '1') return;
        viewport.dataset.carouselSetup = '1';

        const slides = Array.from(track.querySelectorAll<HTMLElement>('.carousel-slide'));
        const total = slides.length;
        if (total === 0) return;

        let current = 0;

        // --- Dots ---
        dotsEl.innerHTML = '';
        if (total > 1) {
            for (let i = 0; i < total; i++) {
                const btn = document.createElement('button');
                btn.setAttribute('aria-label', `Diapositiva ${i + 1}`);
                btn.style.cssText = `display:block;height:10px;width:${i === 0 ? '24px' : '10px'};border-radius:9999px;background:${i === 0 ? 'var(--color-primary)' : '#d1d5db'};border:none;cursor:pointer;padding:0;flex-shrink:0;transition:background 0.2s,width 0.2s;`;
                btn.addEventListener('mouseenter', () => {
                    if (btn.dataset.active !== '1') btn.style.background = 'var(--color-primary)';
                });
                btn.addEventListener('mouseleave', () => {
                    if (btn.dataset.active !== '1') btn.style.background = '#d1d5db';
                });
                btn.addEventListener('click', () => goTo(i));
                dotsEl.appendChild(btn);
            }
        }

        const updateDots = () => {
            dotsEl.querySelectorAll<HTMLButtonElement>('button').forEach((d, i) => {
                const active = i === current;
                d.dataset.active = active ? '1' : '';
                d.style.background = active ? 'var(--color-primary)' : '#d1d5db';
                d.style.width = active ? '24px' : '10px';
            });
        };

        // --- View transition name ---
        const setTransitionName = (index: number) => {
            slides.forEach((slide, i) => {
                const img = slide.querySelector<HTMLImageElement>('[data-poster-id]');
                if (!img) return;
                img.style.viewTransitionName = i === index ? `poster-${img.dataset.posterId}` : '';
            });
        };

        const W = () => slides[0]?.offsetWidth ?? viewport.offsetWidth;

        const goTo = (index: number, animate = true) => {
            current = ((index % total) + total) % total;
            track.style.transition = animate
                ? 'transform 0.35s cubic-bezier(0.25, 1, 0.5, 1)'
                : 'none';
            track.style.transform = `translateX(-${current * W()}px)`;
            slides.forEach((s, i) => s.setAttribute('aria-hidden', String(i !== current)));
            setTransitionName(current);
            updateDots();
        };

        prevBtn.addEventListener('click', () => goTo(current - 1));
        nextBtn.addEventListener('click', () => goTo(current + 1));

        // --- Drag/Swipe ---
        let startX = 0;
        let startY = 0;
        let dragging = false;
        let dragDelta = 0;

        // Recalcular posición al redimensionar
        window.addEventListener('resize', () => goTo(current, false));

        const onStart = (x: number, y: number) => {
            startX = x;
            startY = y;
            dragging = true;
            dragDelta = 0;
            track.style.transition = 'none';
        };
        const onMove = (x: number, y: number) => {
            if (!dragging) return;
            const dx = x - startX;
            const dy = y - startY;
            if (!dragDelta && Math.abs(dy) > Math.abs(dx)) {
                dragging = false;
                return;
            }
            dragDelta = dx;
            const base = -current * W();
            track.style.transform = `translateX(${base + dx}px)`;
        };
        const onEnd = (x: number) => {
            if (!dragging) return;
            dragging = false;
            const dx = x - startX;
            if (Math.abs(dx) > W() * 0.2) {
                goTo(dx < 0 ? current + 1 : current - 1);
            } else {
                goTo(current);
            }
        };

        // Touch
        viewport.addEventListener('touchstart', e => onStart(e.touches[0].clientX, e.touches[0].clientY), {passive: true});
        viewport.addEventListener('touchmove', e => onMove(e.touches[0].clientX, e.touches[0].clientY), {passive: true});
        viewport.addEventListener('touchend', e => onEnd(e.changedTouches[0].clientX), {passive: true});

        // Mouse
        viewport.addEventListener('mousedown', e => {
            e.preventDefault();
            onStart(e.clientX, e.clientY);
        });
        viewport.addEventListener('mousemove', e => onMove(e.clientX, e.clientY));
        viewport.addEventListener('mouseup', e => onEnd(e.clientX));
        viewport.addEventListener('mouseleave', () => {
            if (dragging) onEnd(startX + dragDelta);
        });

        // Evitar click tras drag
        viewport.addEventListener('click', e => {
            if (Math.abs(dragDelta) > 5) {
                e.preventDefault();
                e.stopPropagation();
                dragDelta = 0;
            }
        }, true);

        // Init
        goTo(0, false);

        // Auto-play cada 4 segundos
        let autoplay = setInterval(() => goTo(current + 1), 7000);
        const resetAutoplay = () => {
            clearInterval(autoplay);
            autoplay = setInterval(() => goTo(current + 1), 4000);
        };

        prevBtn.addEventListener('click', resetAutoplay);
        nextBtn.addEventListener('click', resetAutoplay);
        viewport.addEventListener('touchstart', () => clearInterval(autoplay), {passive: true});
        viewport.addEventListener('touchend', () => {
            autoplay = setInterval(() => goTo(current + 1), 4000);
        }, {passive: true});
        viewport.addEventListener('mousedown', () => clearInterval(autoplay));
        viewport.addEventListener('mouseup', () => {
            autoplay = setInterval(() => goTo(current + 1), 4000);
        });
        dotsEl.querySelectorAll<HTMLButtonElement>('button').forEach(btn =>
            btn.addEventListener('click', resetAutoplay)
        );
    }

    // Intento inmediato para cubrir el race condition en la primera carga
    setupCarousel();
    document.addEventListener('astro:page-load', setupCarousel);
</script>
