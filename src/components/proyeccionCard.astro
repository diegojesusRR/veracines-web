---
import Action from "./Action.astro";
import type {Proyeccion} from "../types/Proyeccion";

type Props = {
    proyecciones: Proyeccion[];
    pelicula: {
        id: string;
        image: string;
        nombre: string;
        descripcion: string;
        edadRedomendada: string;
    };
    cine: {
        nombre: string;
        color: string;
    };
    entradas?: {
        espanol?: string;
        vose?: string;
    };
};

const {proyecciones, pelicula, cine, entradas} = Astro.props as Props;

const DIASSEMANA = ['Domingo', 'Lunes', 'Martes', 'Miercoles', 'Jueves', 'Viernes', 'Sabado'];
const MESES = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];

const proyeccionesFuturas = proyecciones.filter((p: Proyeccion) => p.fecha >= new Date());

const diasProyeccion: number[] = [...new Set(proyeccionesFuturas.map((p: Proyeccion) => {
    const anio = p.fecha.getFullYear();
    const mes = p.fecha.getMonth();
    const dia = p.fecha.getDate();
    return +`${anio}${mes.toString().padStart(2, '0')}${dia.toString().padStart(2, '0')}`;
}))];

const mesesProyeccion: number[] = [...new Set(proyeccionesFuturas.map((p: Proyeccion) => p.fecha.getMonth()))];
const entradasLink = entradas?.espanol ?? '';
const entradasVoseLink = entradas?.vose ?? '';
const tieneProyecciones = proyeccionesFuturas.length > 0;
---

<article class="m-4 rounded-2xl overflow-hidden shadow-xl bg-white/90 dark:bg-gray-900/90 backdrop-blur space-y-4" style={`--cine-color: var(--color-${cine.color})`}>
    <a href={`/peliculas/${pelicula.id}`} class="relative min-h-[240px] overflow-hidden block group cursor-pointer">
        <img
                src={`/img/peliculas/${pelicula.image}`}
                alt=""
                aria-hidden="true"
                loading="lazy"
                decoding="async"
                width="1200"
                height="675"
                class="absolute inset-0 w-full h-full object-cover scale-110 blur-md brightness-[0.3] group-hover:brightness-[0.4] transition-[filter] duration-200"
        />

        <div class="relative z-10 min-h-[240px] p-4 sm:p-5 grid grid-cols-[1fr_144px] gap-3 sm:gap-4 items-stretch">
            <div class="min-w-0 flex flex-col justify-between">
                <span class="inline-flex items-center text-[11px] font-bold bg-white/15 backdrop-blur-sm text-white border border-white/20 rounded-full px-3 py-1 w-fit text-center leading-snug">
                    {pelicula.edadRedomendada}
                </span>
                <div class="flex flex-col gap-0.5">
                    <h3 class="text-white text-xl sm:text-3xl font-extrabold leading-tight drop-shadow">
                        {pelicula.nombre}
                    </h3>
                    <span class="inline-flex items-center gap-1 text-white/70 group-hover:text-white text-xs font-medium transition-colors">
                        Ir a la película
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                        </svg>
                    </span>
                </div>
            </div>
            <div class="self-stretch">
                <img
                        class="h-full w-full rounded-xl border-4 border-white/30 shadow-2xl object-cover"
                        src={`/img/peliculas/${pelicula.image}`}
                        alt={`Cartel de ${pelicula.nombre}`}
                        loading="lazy"
                        decoding="async"
                        width="300"
                        height="450"
                        style={`view-transition-name: poster-${pelicula.id}`}
                />
            </div>
        </div>
    </a>

    <section class="px-4 sm:px-5">
        <h4 class="proyeccion-title font-bold mb-2">
            Proyecciones {mesesProyeccion.length > 0 ? `- ${mesesProyeccion.map((x: number) => MESES[x]).join(' y ')}` : ''}
        </h4>

        {
            !tieneProyecciones ? (
                    <div class="sin-proyecciones p-3 rounded-lg">
                        <p class="font-semibold">Actualmente no hay proyecciones disponibles.</p>
                    </div>
            ) : (
                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-2">
                        {diasProyeccion.sort().map((diaProyeccion: number) => {
                            const proyeccionesDia = proyeccionesFuturas.filter((p: Proyeccion) => {
                                const anio = p.fecha.getFullYear();
                                const mes = p.fecha.getMonth();
                                const dia = p.fecha.getDate();
                                return +`${anio}${mes.toString().padStart(2, '0')}${dia.toString().padStart(2, '0')}` === diaProyeccion;
                            });

                            const diaLabel = `${DIASSEMANA[proyeccionesDia[0].fecha.getDay()]} ${proyeccionesDia[0].fecha.getDate()}`;
                            const horas = proyeccionesDia.map((p: Proyeccion) => `${p.hora}h${p.vose ? ' (VOSE)' : ''}`).join(', ');

                            return (
                                            <div class="rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 px-3 py-2 text-center">
                                                        <p class="dia-label font-bold text-md leading-tight">{diaLabel}</p>
                                                        <p class="text-sm text-gray-700 dark:text-gray-300 mt-1 leading-tight">{horas}</p>
                                                    </div>
                            );
                        })}
                    </div>
            )
        }
    </section>

    <section class="px-4 sm:px-5 pb-4">
        <div class="mb-4">
            <span class="flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
                </svg>
                Sinopsis
            </span>
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed line-clamp-3 mb-1.5">
                {pelicula.descripcion}
            </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-2">
            {entradasLink && tieneProyecciones && (
                    <Action
                            as="a"
                            class="flex-1 justify-center"
                            aria-label={`Enlace a los tickets de ${cine.nombre} para la pelicula ${pelicula.nombre}`}
                            href={entradasLink}
                            color={cine.color}
                            target="_blank"
                    >
                        Entradas
                    </Action>
            )}

            {entradasVoseLink && tieneProyecciones && (
                    <Action
                            as="a"
                            class="flex-1 justify-center"
                            aria-label={`Enlace a la cartelera de ${cine.nombre} para la pelicula ${pelicula.nombre} en VOSE`}
                            href={entradasVoseLink}
                            color="secondary"
                            target="_blank"
                    >
                        VOSE
                    </Action>
            )}
        </div>
    </section>
</article>


<style>
    .proyeccion-title { color: var(--cine-color); }
    .dia-label        { color: var(--cine-color); }
    .sin-proyecciones {
        background-color: color-mix(in srgb, var(--cine-color) 10%, transparent);
        color: var(--cine-color);
    }
</style>

