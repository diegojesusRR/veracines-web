---
const { aclaracion, label } = Astro.props;
---

<div class="servicio-card flex flex-col items-center gap-2 text-center">
    <div class="servicio-inner w-full rounded-2xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 shadow-sm p-4 sm:p-5
                flex flex-row items-center gap-4 sm:flex-col sm:gap-3
                transition-all duration-200 hover:shadow-md hover:-translate-y-1 cursor-default">
        <div class="servicio-icon text-primary shrink-0">
            <slot />
        </div>
        <div class="flex flex-col gap-0.5 sm:items-center">
            <p class="text-sm font-bold text-primary leading-tight sm:text-center text-left">{label}</p>
            {aclaracion && (
                <p class="text-gray-400 dark:text-gray-500 text-[11px] leading-snug text-left sm:text-center">{aclaracion}</p>
            )}
        </div>
    </div>
</div>

<style>
    .servicio-icon :global(svg) {
        width: 2.25rem;
        height: 2.25rem;
    }
</style>
