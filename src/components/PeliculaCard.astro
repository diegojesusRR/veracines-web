---
import {CINES} from "../consts/cines";
import ProyeccionesPelicula from "./ProyeccionesPelicula.astro";
const { pelicula } = Astro.props;
---

<article class="space-y-5">

    <!-- Hero: fondo difuminado + póster + edad recomendada -->
    <div class="relative rounded-2xl overflow-hidden shadow-2xl min-h-[180px]">
        <img
            src={`/img/peliculas/${pelicula.image}`}
            alt=""
            aria-hidden="true"
            loading="lazy"
            decoding="async"
            width="1200"
            height="675"
            class="absolute inset-0 w-full h-full object-cover scale-110 blur-md brightness-[0.25]"
        />
        <div class="relative z-10 flex flex-col sm:flex-row items-center sm:items-end justify-between gap-5 p-6">
            <div class="flex flex-col items-center sm:items-start gap-2 sm:self-stretch sm:justify-end">
                <h1 class="text-left text-white text-2xl sm:text-3xl font-extrabold leading-tight text-shadow-[0_2px_10px_rgba(0,0,0,0.5)]">
                    {pelicula.nombre}
                </h1>
                <span class="inline-flex items-center gap-1.5 text-xs font-bold bg-white/15 backdrop-blur-sm text-white border border-white/20 rounded-full px-4 py-1.5 text-center">
                    {pelicula.edadRedomendada}
                </span>
            </div>
            <button
                id="poster-btn"
                class="group relative w-46 sm:w-44 flex-shrink-0 cursor-zoom-in"
                aria-label={`Ver cartel de ${pelicula.nombre} en grande`}
            >
                <img
                    class="w-full rounded-xl border-4 border-white/30 shadow-2xl object-cover transition-transform duration-200 group-hover:scale-[1.03]"
                    src={`/img/peliculas/${pelicula.image}`}
                    alt={`Cartel de ${pelicula.nombre}`}
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                    width="300"
                    height="450"
                    style={`view-transition-name: poster-${pelicula.id}`}
                />
                <span class="absolute inset-0 flex items-center justify-center rounded-xl bg-black/0 group-hover:bg-black/20 transition-colors duration-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-200 drop-shadow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0zm-3-3v2m0 4h.01"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 8v6m-3-3h6"/>
                    </svg>
                </span>
            </button>
        </div>
    </div>

    <!-- Lightbox -->
    <dialog id="poster-lightbox" class="lightbox">
        <div class="lightbox-inner">
            <button id="lightbox-close" class="lightbox-close" aria-label="Cerrar">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
            <img
                src={`/img/peliculas/${pelicula.image}`}
                alt={`Cartel de ${pelicula.nombre}`}
                class="lightbox-img"
                width="600"
                height="900"
            />
        </div>
    </dialog>

    <!-- Sinopsis -->
    <section class="bg-white/85 dark:bg-gray-900/85 backdrop-blur rounded-2xl shadow p-5 sm:p-6">
        <h2 class="text-primary font-bold text-lg mb-3 flex items-center gap-2">
            📖 Sinopsis
        </h2>
        <p class="text-gray-700 dark:text-gray-300 leading-relaxed text-justify">{pelicula.descripcion}</p>
    </section>

    <!-- Próximas proyecciones -->
    <section class="bg-white/85 dark:bg-gray-900/85 backdrop-blur rounded-2xl shadow p-5 sm:p-6">
        <h2 class="text-primary font-bold text-lg mb-4 flex items-center gap-2">
            🎬 Próximas proyecciones
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {CINES.map(cine => <ProyeccionesPelicula cine={cine} pelicula={pelicula}/>)}
        </div>
    </section>

    <!-- Tráiler -->
    <section class="rounded-2xl overflow-hidden shadow-xl">
        <div class="bg-gray-900 px-5 py-3 flex items-center gap-2">
            <h2 class="text-white font-bold text-base flex items-center gap-2">
                🎥 Tráiler oficial
            </h2>
        </div>
        <div class="aspect-video bg-black">
            <iframe
                class="w-full h-full"
                src={pelicula.videoUrl}
                title={`Tráiler de ${pelicula.nombre}`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
            ></iframe>
        </div>
    </section>

</article>

<style>
    .lightbox {
        padding: 0;
        border: none;
        background: transparent;
        max-width: 100vw;
        max-height: 100vh;
        width: 100vw;
        height: 100vh;
    }
    .lightbox::backdrop {
        background: rgba(0, 0, 0, 0.85);
    }
    .lightbox-inner {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }
    .lightbox-img {
        max-height: 90vh;
        max-width: 90vw;
        border-radius: 12px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.6);
        object-fit: contain;
    }
    .lightbox-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        color: white;
        background: rgba(0,0,0,0.4);
        border: none;
        border-radius: 9999px;
        padding: 0.4rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
        z-index: 10;
    }
    .lightbox-close:hover { background: rgba(0,0,0,0.7); }
</style>

<script>
    document.addEventListener('astro:page-load', () => {
        const btn      = document.getElementById('poster-btn');
        const dialog   = document.getElementById('poster-lightbox') as HTMLDialogElement | null;
        const closeBtn = document.getElementById('lightbox-close');

        btn?.addEventListener('click', () => dialog?.showModal());
        closeBtn?.addEventListener('click', () => dialog?.close());
        dialog?.addEventListener('click', (e) => {
            if (e.target === dialog) dialog.close();
        });
    });
</script>
