---
import Burguer from '../components/icons/burguer.astro';
import Popcorn from '../components/icons/popcorn.astro';
import Icecream from '../components/icons/icecream.astro';
import Parking from '../components/icons/parking.astro';
import Projector from '../components/icons/projector.astro';
import {CINES} from "../consts/cines";
import Servicio from "./Servicio.astro";
import Climatizacion from "./icons/climatizacion.astro";

const vera  = CINES.find(x => x.url === 'vera');
const regio = CINES.find(x => x.url === 'regio');
---

<section class="w-full" aria-labelledby="servicios-titulo">
    <div class="text-center mb-6 space-y-2">
        <h2 id="servicios-titulo" class="text-2xl font-extrabold text-primary">
            Todo lo que necesitas
        </h2>
        <p class="text-gray-500 dark:text-gray-400 text-sm max-w-md mx-auto">
            Más que una película — bocatería, palomitas, helados y todo el confort
            para que solo te preocupes de disfrutar.
        </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4">
        <Servicio label="Proyector 2K">
            <Projector />
        </Servicio>
        <Servicio label="Palomitas">
            <Popcorn />
        </Servicio>
        <Servicio label="Helados">
            <Icecream />
        </Servicio>
        <Servicio label="Bocadillos y Hamburguesas" aclaracion={`Solo en ${vera?.nombre}`}>
            <Burguer />
        </Servicio>
        <Servicio
            label="Parking Gratuito"
            aclaracion={`Solo en ${vera?.nombre}`}
        >
            <Parking />
        </Servicio>
        <Servicio
            label="Climatización"
            aclaracion={`Solo en ${regio?.nombre}`}
        >
            <Climatizacion />
        </Servicio>
    </div>
</section>